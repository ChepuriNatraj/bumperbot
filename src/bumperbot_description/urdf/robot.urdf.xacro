<?xml version="1.0"?>
<robot name="agv" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ================= ARGS ================= -->
  <xacro:arg name="is_ignition" default="true"/>
  <xacro:arg name="is_sim" default="true"/>

  <!-- ================= INCLUDES ================= -->
  <xacro:include filename="$(find bumperbot_description)/urdf/robot_gazebo.xacro" />
  <xacro:include filename="$(find bumperbot_description)/urdf/robot_ros2_control.xacro" />

  <!-- ================= PROPERTIES ================= -->
  <xacro:property name="base_length" value="0.86"/>
  <xacro:property name="base_width"  value="0.50"/>
  <xacro:property name="base_height" value="0.26"/>

  <xacro:property name="wheel_radius" value="0.0585"/>
  <xacro:property name="wheel_width"  value="0.025"/>

  <xacro:property name="wheel_xoff" value="0.132"/>
  <xacro:property name="wheel_ygap" value="0.027"/>
  <xacro:property name="wheel_zoff" value="${base_height/2}"/>

  <xacro:property name="caster_xoff" value="${base_length/2 - 0.08}"/>
  <xacro:property name="caster_radius" value="0.02925"/>

  <!-- ================= INERTIA MACROS ================= -->
  <xacro:macro name="box_inertia" params="m w h d">
    <inertial>
      <mass value="${m}"/>
      <origin xyz="0 0 0"/>
      <inertia
        ixx="${(m/12)*(h*h+d*d)}"
        ixy="0" ixz="0"
        iyy="${(m/12)*(w*w+d*d)}"
        iyz="0"
        izz="${(m/12)*(w*w+h*h)}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <origin xyz="0 0 0"/>
      <inertia
        ixx="${(m/12)*(3*r*r+h*h)}"
        ixy="0" ixz="0"
        iyy="${(m/12)*(3*r*r+h*h)}"
        iyz="0"
        izz="${0.5*m*r*r}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="sphere_inertia" params="m r">
    <inertial>
      <mass value="${m}"/>
      <origin xyz="0 0 0"/>
      <inertia
        ixx="${0.4*m*r*r}"
        ixy="0" ixz="0"
        iyy="${0.4*m*r*r}"
        iyz="0"
        izz="${0.4*m*r*r}"/>
    </inertial>
  </xacro:macro>

  <!-- ================= MATERIALS ================= -->
  <material name="blue">
    <color rgba="0.1 0.1 1.0 1.0"/>
  </material>
  <material name="gray">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="cyan">
    <color rgba="0 1 1 1"/>
  </material>
  <material name="dark_grey">
    <color rgba="0.3 0.3 0.3 1"/>
  </material>

  <!-- ================= BASE FOOTPRINT ================= -->
  <link name="base_footprint"/>

  <!-- ================= BASE LINK ================= -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="5" w="${base_width}" h="${base_height}" d="${base_length}"/>
  </link>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${base_height/2 + wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- ================= WHEEL MACRO ================= -->
  <xacro:macro name="wheel" params="prefix side">

    <link name="${prefix}_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="gray"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia m="0.5" r="${wheel_radius}" h="${wheel_width}"/>
    </link>

    <joint name="${prefix}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_link"/>
      <origin
        xyz="${-wheel_xoff}
             ${side*(base_width/2 + wheel_width/2 + wheel_ygap)}
             ${-wheel_zoff}"
        rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>

  </xacro:macro>

  <!-- bumperbot uses wheel_right_joint / wheel_left_joint naming -->
  <xacro:macro name="wheel_right" params="prefix side">
    <link name="${prefix}_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="gray"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia m="0.5" r="${wheel_radius}" h="${wheel_width}"/>
    </link>
    <joint name="${prefix}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_link"/>
      <origin
        xyz="${-wheel_xoff}
             ${side*(base_width/2 + wheel_width/2 + wheel_ygap)}
             ${-wheel_zoff}"
        rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:wheel_right prefix="wheel_right" side="-1"/>
  <xacro:wheel_right prefix="wheel_left"  side="1"/>

  <!-- ================= CASTER ================= -->
  <link name="caster_front_link">
    <visual>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
      <material name="cyan"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
    </collision>
    <xacro:sphere_inertia m="0.3" r="${caster_radius}"/>
  </link>

  <joint name="caster_front_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_front_link"/>
    <origin
      xyz="${caster_xoff}
          0
          -0.15925"
      rpy="0 0 0"/>
  </joint>

  <!-- ================= IMU LINK ================= -->
  <link name="imu_link">
    <visual>
      <geometry>
        <box size="0.04 0.04 0.02"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.05 0.05 0.02"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="0.1" w="0.05" h="0.02" d="0.05"/>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin
      xyz="-0.082 0.01 ${base_height/2 - 0.03}"
      rpy="0 0 ${pi}"/>
  </joint>

  <!-- ================= LASER LINK ================= -->
  <!-- named laser_link to match bumperbot_gazebo.xacro sensor reference -->
  <link name="laser_link">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.04"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.04"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="0.2" r="0.05" h="0.04"/>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_link"/>
    <origin
      xyz="${base_length/2 - 0.10}
          -0.005
          ${base_height/2 + 0.02}"
      rpy="0 0 0"/>
  </joint>

</robot>